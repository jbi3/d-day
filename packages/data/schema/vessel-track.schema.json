{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "vessel-track.schema.json",
	"title": "VesselTrack",
	"type": "object",
	"additionalProperties": false,
	"required": ["vesselId", "waypoints"],
	"properties": {
		"vesselId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
		"waypoints": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["time", "position", "sources"],
				"properties": {
					"time": { "type": "string", "format": "date-time" },
					"position": {
						"type": "array",
						"items": { "type": "number" },
						"minItems": 2,
						"maxItems": 2
					},
					"sources": {
						"type": "array",
						"items": { "type": "string" },
						"minItems": 1
					},
					"disputedBy": {
						"type": "array",
						"items": { "$ref": "#/definitions/dispute" }
					},
					"note": { "type": "string" }
				}
			}
		}
	},
	"definitions": {
		"dispute": {
			"type": "object",
			"additionalProperties": false,
			"required": ["source", "claim"],
			"properties": {
				"source": { "type": "string" },
				"claim": { "type": "string", "minLength": 1 }
			}
		}
	}
}
