{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "frontline.schema.json",
	"type": "object",
	"additionalProperties": false,
	"required": ["segments"],
	"properties": {
		"$schema": { "type": "string" },
		"segments": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "keyframes", "sources"],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"label": { "type": "string" },
					"closed": {
						"type": "boolean",
						"description": "If true, the path is treated as a closed loop (perimeter of a pocket)."
					},
					"keyframes": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": ["time", "path"],
							"properties": {
								"time": { "type": "string", "format": "date-time" },
								"path": {
									"type": "array",
									"minItems": 2,
									"items": {
										"type": "array",
										"minItems": 2,
										"maxItems": 2,
										"items": { "type": "number" }
									}
								}
							}
						}
					},
					"sources": {
						"type": "array",
						"minItems": 1,
						"items": { "type": "string", "minLength": 1 }
					}
				}
			}
		}
	}
}
