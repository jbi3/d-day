{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "unit.schema.json",
	"title": "Unit",
	"type": "object",
	"additionalProperties": false,
	"required": ["id", "side", "country", "echelon", "branch", "name", "sources"],
	"properties": {
		"id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
		"side": { "type": "string", "enum": ["allied", "axis"] },
		"country": { "type": "string", "pattern": "^[A-Z]{2,3}$" },
		"echelon": {
			"type": "string",
			"enum": ["division", "regiment", "battalion", "company"]
		},
		"branch": {
			"type": "string",
			"enum": ["infantry", "airborne", "armor", "engineer", "artillery", "naval", "air"]
		},
		"name": { "type": "string", "minLength": 1 },
		"shortName": { "type": "string" },
		"strength": { "type": "integer", "minimum": 1 },
		"axisAffiliation": { "type": "string", "enum": ["wehrmacht", "ss"] },
		"commander": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "rank"],
			"properties": {
				"name": { "type": "string", "minLength": 1 },
				"rank": { "type": "string", "minLength": 1 }
			}
		},
		"casualties": {
			"type": "object",
			"additionalProperties": false,
			"required": ["total"],
			"properties": {
				"total": { "type": "integer", "minimum": 0 },
				"byPhase": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["phase"],
						"properties": {
							"phase": { "type": "string", "minLength": 1 },
							"killed": { "type": "integer", "minimum": 0 },
							"wounded": { "type": "integer", "minimum": 0 },
							"missing": { "type": "integer", "minimum": 0 },
							"captured": { "type": "integer", "minimum": 0 }
						}
					}
				}
			}
		},
		"sources": {
			"type": "array",
			"items": { "type": "string" },
			"minItems": 1
		}
	}
}
