{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "movement.schema.json",
	"title": "Movement",
	"type": "object",
	"additionalProperties": false,
	"required": ["unitId", "waypoints"],
	"properties": {
		"unitId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
		"waypoints": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "#/definitions/waypoint" }
		}
	},
	"definitions": {
		"waypoint": {
			"type": "object",
			"additionalProperties": false,
			"required": ["time", "position", "sources"],
			"properties": {
				"time": { "type": "string", "format": "date-time" },
				"position": {
					"type": "array",
					"items": { "type": "number" },
					"minItems": 2,
					"maxItems": 2
				},
				"sources": {
					"type": "array",
					"items": { "type": "string" },
					"minItems": 1
				},
				"disputedBy": {
					"type": "array",
					"items": { "$ref": "#/definitions/dispute" }
				},
				"note": { "type": "string" }
			}
		},
		"dispute": {
			"type": "object",
			"additionalProperties": false,
			"required": ["source", "claim"],
			"properties": {
				"source": { "type": "string" },
				"claim": { "type": "string", "minLength": 1 }
			}
		}
	}
}
